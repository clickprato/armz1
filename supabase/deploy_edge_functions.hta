<html>
<head>
<title>Supabase Multi-Deploy Pro</title>
<hta:application id="oHTA" border="thin" scroll="no" windowstate="normal" width="550" height="520">
<style>
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 25px; background-color: #1c1c1c; color: #e0e0e0; }
    h3 { color: #3ecf8e; border-bottom: 1px solid #333; padding-bottom: 10px; margin-top: 0; }
    label { font-size: 11px; color: #888; font-weight: bold; text-transform: uppercase; display: block; margin-top: 15px; }
    input { width: 100%; padding: 10px; margin: 5px 0; border: 1px solid #333; background: #2a2a2a; color: white; border-radius: 4px; box-sizing: border-box; }
    input:focus { border-color: #3ecf8e; outline: none; }
    button { width: 100%; padding: 14px; background-color: #3ecf8e; color: #1c1c1c; border: none; cursor: pointer; font-weight: bold; border-radius: 4px; margin-top: 20px; font-size: 14px; }
    button:hover { background-color: #34b27b; }
    .status-box { font-size: 11px; color: #666; margin-top: 20px; padding: 10px; border: 1px dashed #333; border-radius: 4px; line-height: 1.5; }
    .highlight { color: #3ecf8e; }
</style>
</head>

<body>
    <h3>🚀 Deploy de Clone ClickPrato</h3>
    
    <label>Project Ref (ID do Projeto):</label>
    <input type="text" id="projID" placeholder="ex: ysvvburadsnjsnjvxehp">
    
    <label>Access Token (sbp_...):</label>
    <input type="password" id="accessToken" placeholder="Cole o token da conta">

    <label>Senha do Banco de Dados (Database Password):</label>
    <input type="password" id="dbPassword" placeholder="Senha definida na criação do projeto">
    
    <button onclick="ExecutarDeployCompleto()">DISPARAR DEPLOY TOTAL</button>

    <div class="status-box">
        <b>O que este script fará:</b><br>
        1. <span class="highlight">Link:</span> Conecta esta pasta ao projeto remoto.<br>
        2. <span class="highlight">DB Push:</span> Sobe as tabelas e o RPC corrigido.<br>
        3. <span class="highlight">Functions:</span> Deploy de calcular-distancia, ga4-analytics, registrar-uso-cupom e update-cron.
    </div>

    <script language="vbscript">
        Sub ExecutarDeployCompleto()
            Dim shell, projRef, token, dbPass, comando
            
            ' Trim remove espaços extras acidentais no início ou fim das strings
            projRef = Trim(document.getElementById("projID").value)
            token = Trim(document.getElementById("accessToken").value)
            dbPass = Trim(document.getElementById("dbPassword").value)
            
            If projRef = "" Or token = "" Or dbPass = "" Then
                MsgBox "Todos os campos sao obrigatorios!", 16, "Erro de Validacao"
                Exit Sub
            End If

            Set shell = CreateObject("WScript.Shell")

            ' Montagem do comando sequencial:
            ' 1. set "VAR=VALOR" com aspas garante que o Windows não quebre o formato do token
            ' 2. link associa o projeto local ao ID remoto (exige senha)
            ' 3. db push aplica os arquivos da pasta supabase/migrations
            ' 4. functions deploy sobe as 4 pastas da pasta supabase/functions
            
comando = "cmd.exe /k " & _
          "set ""SUPABASE_ACCESS_TOKEN=" & token & """ && " & _
          "echo [1/3] CONECTANDO AO PROJETO REMOTO... && " & _
          "npx supabase link --project-ref " & projRef & " --password " & dbPass & " && " & _
          "echo. && echo [2/3] FORCANDO SINCRONIZACAO DE TABELAS... && " & _
          "npx supabase db push --include-all --yes && " & _
          "echo. && echo [3/3] FAZENDO DEPLOY DAS 4 EDGE FUNCTIONS... && " & _
          "npx supabase functions deploy --project-ref " & projRef & " --no-verify-jwt --yes && " & _
          "echo. && echo === PROCESSO CONCLUIDO COM SUCESSO! ==="

            shell.Run comando
        End Sub
    </script>
</body>
</html>